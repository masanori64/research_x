flowchart LR
  %% 完成形の証拠パイプライン図: text/media/provider候補が同じ証拠条件を通る形を見る

  classDef source fill:#e7f0f8,stroke:#49657a,color:#17212b
  classDef candidate fill:#fff4cf,stroke:#8a6d1d,color:#17212b
  classDef ready fill:#e9f6ee,stroke:#49745a,color:#17212b
  classDef gate fill:#fbe4e4,stroke:#b42318,color:#17212b,stroke-width:2px

  raw["Raw Source<br/>投稿・ブックマーク・メディア・取得記録"]:::source
  projections["候補信号<br/>FTS / metadata / relation / vector / OCR"]:::candidate
  provider["Provider候補<br/>embedding / rerank / Reader"]:::gate
  restore["復元<br/>tweet・quote・media・accountへ戻す"]:::ready
  bundle["Source Bundle<br/>根拠束"]:::ready
  chunk["Context Chunk<br/>回答単位"]:::ready
  citation["Citation<br/>支えを示す"]:::ready
  answer["Answer / Abstain<br/>評価結果つきで返す"]:::ready
  feedback["Feedback / Eval<br/>品質改善へ戻す"]:::candidate

  raw --> projections --> restore --> bundle --> chunk --> citation --> answer
  provider -. "承認済みなら候補を追加" .-> projections
  answer --> feedback --> projections
  restore -. "戻せない候補は捨てる" .-> projections
