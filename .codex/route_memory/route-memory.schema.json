{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-x.local/schemas/route-memory.schema.json",
  "title": "research_x Route Memory Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "purpose",
    "not_evidence",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "not_evidence": {
      "const": true
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "owner_skill",
        "task_family",
        "artifact_kind",
        "status",
        "last_verified_at",
        "positive_triggers",
        "negative_triggers",
        "applies_when",
        "do_not_use_when",
        "canonical_first_action",
        "known_failed_routes",
        "success_verification",
        "gates",
        "source_pointers",
        "not_evidence"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "owner_skill": {
          "type": "string",
          "minLength": 1
        },
        "task_family": {
          "type": "string",
          "minLength": 1
        },
        "artifact_kind": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "blocked",
            "deprecated"
          ]
        },
        "last_verified_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "positive_triggers": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "negative_triggers": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "applies_when": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "do_not_use_when": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "canonical_first_action": {
          "type": "string",
          "minLength": 1
        },
        "known_failed_routes": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "success_verification": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "gates": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "source_pointers": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "not_evidence": {
          "const": true
        }
      }
    }
  }
}
