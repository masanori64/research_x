direction: down

vars: {
  ok: "#e7f5ed"
  warn: "#fff4cf"
  stop: "#fbe4e4"
  ink: "#22313f"
}

classes: {
  box: {
    style.border-radius: 5
    style.stroke: "#4f6578"
    style.font-color: ${ink}
  }
  ok: {
    style.fill: ${ok}
  }
  warn: {
    style.fill: ${warn}
  }
  stop: {
    style.fill: ${stop}
    style.stroke: "#b42318"
    style.stroke-width: 2
  }
}

ask: "provider / network / quota を使う候補ルートか？" {
  shape: diamond
  style.fill: ${warn}
  style.stroke: "#8a6d1d"
}

local: {
  label: "承認なしで進められる"
  grid-columns: 3
  fake: "fake/local provider\n実APIを呼ばない" {
    class: box
    class: ok
  }
  static: "静的検査\nコード・設定・見積もり" {
    class: box
    class: ok
  }
  tests: "monkeypatch済みテスト\n通信を差し替える" {
    class: box
    class: ok
  }
}

guard: {
  label: "ProviderApiBudgetGuard"
  grid-columns: 3
  budget: "料金・上限・停止条件\nfree-tierも対象" {
    class: box
    class: stop
  }
  secrets: "secrets / login\n資格情報・セッション" {
    class: box
    class: stop
  }
  provider: "real API call\nembedding / OCR / rerank / Reader / search" {
    class: box
    class: stop
  }
}

end: {
  grid-columns: 2
  proceed: "候補を作る\nまだ回答根拠ではない" {
    class: box
    class: ok
  }
  stop: "provider_gated\n承認・予算・範囲を確認" {
    class: box
    class: stop
  }
}

evidence: "後続のmode別確認\nevidence_package は citation candidates\nanswer は claim support を確認" {
  class: box
  class: ok
}

local -> guard: "provider-backedへ変えるなら"
guard -> end: "判断"

ask -> local.fake: "いいえ"
local.fake -> local.static
local.static -> local.tests
local.tests -> end.proceed
end.proceed -> evidence

ask -> guard.budget: "はい" {
  style.stroke: "#b42318"
}
guard.budget -> guard.secrets
guard.secrets -> guard.provider
guard.provider -> end.stop
