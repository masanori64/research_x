stateDiagram-v2
  %% 現状の証拠パイプライン図: Mermaid UML stateDiagramで候補が根拠へ昇格する条件を見る
  direction LR

  state "原本<br/>X投稿・ブックマーク・メディア" as RawSource
  state "検索用ビュー<br/>memory_documents / OCR text / labels<br/>再生成可能で証拠ではない" as SearchProjection
  state "検索候補<br/>SQLite FTS / BM25 / metadata / relation<br/>まだ根拠ではない" as Candidate
  state "Source Bundle<br/>tweet・quote・media・authorへ戻る" as SourceBundle
  state "Context Chunk<br/>回答に入る範囲へ切る" as ContextChunk
  state "Citation<br/>source ID と claim を結ぶ" as Citation
  state "Claim Support<br/>主張ごとの支えを見る" as ClaimSupport
  state "Answer Boundary<br/>answer / review / hypothesis_only" as AnswerBoundary
  state "source_not_restored<br/>候補止まり" as SourceNotRestored
  state "citation_missing<br/>根拠にしない" as CitationMissing
  state "needs_review<br/>回答支えにしない" as NeedsReview
  state "control artifact<br/>説明用で根拠ではない" as ControlArtifact

  [*] --> RawSource
  RawSource --> SearchProjection
  SearchProjection --> Candidate

  Candidate --> SourceBundle: 復元できた
  SourceBundle --> ContextChunk
  ContextChunk --> Citation
  Citation --> ClaimSupport
  ClaimSupport --> AnswerBoundary

  Candidate --> SourceNotRestored: 復元できない
  ContextChunk --> CitationMissing: citation不可
  ClaimSupport --> NeedsReview: 主張支え不足
  Candidate --> ControlArtifact: 図・WBS・要約由来
