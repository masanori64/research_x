stateDiagram-v2
  %% 完成形の provider / quota guard 図: Mermaid UML stateDiagramで承認済みProviderの状態遷移を見る
  direction LR

  state "provider-backed route<br/>embedding / native media / OCR / Reader<br/>rerank / external search / managed RAG" as ProviderLane
  state "明示承認を確認" as ApprovalCheck
  state "止める<br/>承認・価格・上限・停止条件が不明" as Stop
  state "traceに記録<br/>provider_gated / skip reason" as Record
  state "offline estimate<br/>件数・費用・scope" as Estimate
  state "ProviderApiBudgetGuard<br/>max calls / max USD / price source" as Guard
  state "最小範囲で実行<br/>結果は候補扱い" as MinimalRun
  state "candidates<br/>answer authorityなし" as Candidate
  state "後続で昇格確認<br/>Source Bundle / Context Chunk / Citation<br/>AnswerAuthorityGatekeeper" as EvidencePromotion

  [*] --> ProviderLane
  ProviderLane --> ApprovalCheck

  ApprovalCheck --> Stop: 承認なし
  Stop --> Record

  ApprovalCheck --> Estimate: 承認あり
  Estimate --> Guard

  Guard --> Stop: 失敗
  Guard --> MinimalRun: 通過
  MinimalRun --> Candidate
  Candidate --> EvidencePromotion
  EvidencePromotion --> Record
