flowchart TB
  %% 完成形の全体アーキテクチャ図: AIの外部記憶として広く探し、狭く答える

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef gate fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px
  classDef side fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5

  subgraph row1["質問を候補に変える"]
    direction LR
    request["人 / AI agent<br/>query・objective<br/>context budget"]:::main
    lens["SearchLens / RetrievalPolicy<br/>corpus scope・source weights<br/>inference stance"]:::main
    policy["ObjectiveRoutePolicy<br/>目的とbudgetからrouteを選ぶ"]:::main
    portfolio["Retrieval And Route Portfolio [wide]<br/>local: exact / SQLite FTS / BM25 / metadata / relation expansion<br/>expansion: semantic vectors / Corpus2Skill / graph-topic hints<br/>provider-backed: native media / OCR / Reader / rerank / external search / managed RAG"]:::gate
    request --> lens --> policy --> portfolio
  end

  guard["ProviderApiBudgetGuard<br/>承認・見積・上限・停止条件"]:::gate

  subgraph row2["候補を回答にできるか見る"]
    direction LR
    candidates["Search Results / Candidates<br/>route_id・score・why_relevant<br/>restore_path・skip reason"]:::main
    bundle["Source Bundle<br/>tweet・quote・media・author"]:::main
    chunk["Context Chunk<br/>bounded answer input"]:::main
    citation["Citation<br/>specific claim support"]:::main
    authority["AnswerAuthorityGatekeeper<br/>claim supportを判定"]:::main
    boundary["Answer Boundary<br/>answer / abstain / needs_review<br/>source_not_restored / citation_missing<br/>hypothesis_only / provider_gated / blocked"]:::main
    bundle --> chunk --> citation
    candidates --> bundle
    citation --> authority --> boundary
  end

  interface["Tool Interface Layer<br/>stable JSON: status・citations・trace"]:::main
  feedback["Eval / Audit / Feedback<br/>restoration rate・citation coverage・route gaps"]:::side

  portfolio --> candidates
  portfolio -. "provider-backedは実行前guard" .-> guard
  guard -. "candidate or provider_gated" .-> candidates
  boundary --> interface
  interface -. "品質と失敗理由" .-> feedback
