flowchart TB
  %% provider / quota guard 図: provider-backed 候補ルートだけを実行前に止める

  classDef ok fill:#e9f6ee,stroke:#49745a,color:#17212b
  classDef check fill:#fff4cf,stroke:#8a6d1d,color:#17212b
  classDef stop fill:#fbe4e4,stroke:#b42318,color:#17212b,stroke-width:2px

  route["候補ルート"]:::check
  local["local / fake / static<br/>そのまま候補を作る"]:::ok
  asks_provider{"provider / network / quota を使うか？"}:::check
  guard["ProviderApiBudgetGuard<br/>承認・価格・上限・停止条件を確認"]:::stop
  asks_secret{"ログイン・secretsを使うか？"}:::check
  secret_gate["止める<br/>資格情報・セッションの扱いを確認"]:::stop
  blocked["provider_gated<br/>free-tier / trial / zero-dollar quota も止める"]:::stop
  candidate["候補として返す<br/>まだ回答根拠ではない"]:::ok
  evidence["後続で確認<br/>Source Bundle / Context Chunk / Citation / AnswerAuthorityGatekeeper"]:::ok

  route --> asks_provider
  asks_provider -->|"いいえ"| local --> candidate
  asks_provider -->|"はい"| guard
  guard -->|"承認済み"| asks_secret
  guard -->|"freeze / 予算不明"| blocked
  asks_secret -->|"いいえ"| candidate
  asks_secret -->|"はい"| secret_gate --> blocked
  candidate --> evidence
