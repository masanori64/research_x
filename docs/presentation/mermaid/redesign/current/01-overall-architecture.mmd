flowchart TB
  %% 現状の全体アーキテクチャ図: 質問から返答までの主経路を読む

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef note fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5
  classDef gate fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px

  start["人 / Codex<br/>質問と目的"]:::main
  receive["依頼を受ける<br/>制約を確認"]:::main
  lens["検索方針<br/>SearchLens"]:::main
  routes["候補を探す<br/>SQLite / FTS / 関係"]:::main
  source["原本へ戻す<br/>Source Bundle"]:::main
  judge["返答を決める<br/>Citation / 停止理由"]:::main
  result["AIへ返す<br/>status / citations / trace"]:::main

  local["X原本・メディア<br/>検索の出発点"]:::note
  provider["外部Provider/API<br/>承認まで停止"]:::gate
  review["図・WBS・監査<br/>説明用"]:::note

  subgraph row1["依頼から検索方針まで"]
    direction LR
    start --> receive --> lens
  end

  subgraph row2["候補から返答まで"]
    direction LR
    routes --> source --> judge --> result
  end

  lens --> routes
  local -. "参照" .-> routes
  provider -. "停止状態も記録" .-> routes
  result -. "状態を残す" .-> review
