flowchart TB
  %% 完成形の証拠パイプライン図: どの検索経路でも同じ根拠条件を通す

  classDef step fill:#e9f6ee,stroke:#49745a,color:#17212b
  classDef candidate fill:#fff4cf,stroke:#8a6d1d,color:#17212b
  classDef gate fill:#fbe4e4,stroke:#b42318,color:#17212b,stroke-width:2px
  classDef loop fill:#f3f4f6,stroke:#6b7280,color:#17212b

  raw["原本<br/>投稿・ブックマーク・メディア・取得記録"]:::step
  signals["候補信号<br/>text / media / relation / provider"]:::candidate
  restore["復元<br/>tweet・quote・media・accountへ戻す"]:::step
  citation["Citation<br/>回答の支えを明示する"]:::step
  answer["返答<br/>回答・棄権・レビュー待ち"]:::step
  reject["捨てる<br/>戻せない候補は根拠にしない"]:::gate
  improve["評価とfeedback<br/>次の検索品質へ戻す"]:::loop

  raw --> signals --> restore --> citation --> answer
  signals -. "復元不可" .-> reject
  answer -. "品質を見る" .-> improve
  improve -. "候補作りを改善" .-> signals
