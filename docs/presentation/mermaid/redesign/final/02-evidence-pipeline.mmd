stateDiagram-v2
  %% 完成形の証拠パイプライン図: Mermaid UML stateDiagramでevidence levelの昇格を見る
  direction LR

  state "raw source<br/>posts・media・provider run artifacts" as RawSource
  state "searchable projection<br/>memory_documents・retrieval text・OCR/VLM text<br/>証拠ではなく再生成可能" as Projection
  state "candidate signal<br/>local / semantic / media / provider<br/>answer authorityなし" as Candidate
  state "source bundle<br/>tweet・quote・media・author・URL・timestamp・hash" as SourceBundle
  state "context chunk<br/>bounded answer input" as ContextChunk
  state "citation annotation<br/>source ID と chunk を固定" as Citation
  state "claim support<br/>specific answer claimを支える" as ClaimSupport
  state "answer_support<br/>回答に使える" as AnswerSupport
  state "Answer Boundary<br/>answer / abstain / review" as AnswerBoundary
  state "source_not_restored" as SourceNotRestored
  state "citation_missing" as CitationMissing
  state "hypothesis_only / needs_review" as HypothesisOnly
  state "provider_gated" as ProviderGated
  state "eval / audit / feedback<br/>restoration rate・citation coverage・route gaps" as Feedback

  [*] --> RawSource
  RawSource --> Projection
  Projection --> Candidate

  Candidate --> SourceBundle: restore_pathあり
  SourceBundle --> ContextChunk
  ContextChunk --> Citation
  Citation --> ClaimSupport
  ClaimSupport --> AnswerSupport
  AnswerSupport --> AnswerBoundary

  Candidate --> SourceNotRestored: restore不可
  ContextChunk --> CitationMissing: annotation不可
  Citation --> HypothesisOnly: claim支え不足
  Candidate --> ProviderGated: guard停止
  AnswerBoundary --> Feedback
  Feedback --> Candidate: 改善
