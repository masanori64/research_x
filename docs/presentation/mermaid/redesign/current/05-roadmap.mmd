flowchart LR
  %% 現状のWBS / ロードマップ図: いまの完成・staging・provider_gated を4層で見る

  classDef done fill:#e9f6ee,stroke:#49745a,color:#17212b
  classDef staging fill:#fff4cf,stroke:#8a6d1d,color:#17212b
  classDef gated fill:#fbe4e4,stroke:#b42318,color:#17212b,stroke-width:2px
  classDef next fill:#e7f0f8,stroke:#49657a,color:#17212b

  subgraph source["Source Layer"]
    source_done["原本ストア<br/>実装済み"]:::done
    source_gate["外部source候補<br/>provider_gated"]:::gated
  end

  subgraph evidence["Evidence Layer"]
    evidence_done["Source Bundle / Context Chunk<br/>実装済み"]:::done
    media_stage["OCR / media evidence<br/>staging"]:::staging
  end

  subgraph retrieval["Retrieval-Eval Layer"]
    local_done["SQLite / FTS / relation<br/>実装済み"]:::done
    vector_stage["vector backend 比較<br/>staging"]:::staging
    provider_gate["実Provider品質評価<br/>provider_gated"]:::gated
  end

  subgraph interface["Tool Interface Layer"]
    tool_done["AI向けJSON契約<br/>実装済み"]:::done
    observe_next["見える化と監査<br/>継続強化"]:::next
  end

  source_done --> evidence_done --> local_done --> tool_done
  source_gate -. "承認後" .-> provider_gate
  media_stage --> observe_next
  vector_stage --> provider_gate
