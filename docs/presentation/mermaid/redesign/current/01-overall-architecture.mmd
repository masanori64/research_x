flowchart TB
  %% 現状の全体アーキテクチャ図: 質問から返答までの主経路と、周辺の外部設計面を見る

  classDef main fill:#e9f6ee,stroke:#49745a,color:#17212b
  classDef input fill:#e7f0f8,stroke:#49657a,color:#17212b
  classDef gate fill:#fbe4e4,stroke:#b42318,color:#17212b,stroke-width:2px
  classDef support fill:#f3f4f6,stroke:#6b7280,color:#17212b

  question["人 / Codex<br/>質問と目的を渡す"]:::input

  subgraph core["research_x の主経路"]
    receive["依頼を受ける<br/>目的・制約・保存可否を確認"]:::main
    search["手元の記憶を探す<br/>SQLite / FTS / 関係"]:::main
    restore["原本に戻す<br/>Source Bundle を作る"]:::main
    decide["返答を決める<br/>Citation か停止理由"]:::main
  end

  result["返す結果<br/>answer / needs_review / provider_gated"]:::input

  subgraph outside["外部設計として見る範囲"]
    raw["X原本・メディア<br/>検索の出発点"]:::support
    provider["外部Provider/API<br/>現状は承認まで停止"]:::gate
    review["WBS・図・監査<br/>説明と確認用"]:::support
  end

  question --> receive --> search --> restore --> decide --> result
  raw -. "原本として支える" .-> search
  provider -. "使わない時は停止" .-> search
  decide -. "状態を残す" .-> review
