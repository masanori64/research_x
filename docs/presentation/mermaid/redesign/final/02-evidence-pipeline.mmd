flowchart LR
  %% 完成形の証拠パイプライン図: どの検索経路でも同じ根拠条件を通す

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef stop fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px
  classDef note fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5

  raw["原本<br/>投稿・メディア・取得記録"]:::main
  signal["候補信号<br/>local / media / provider<br/>まだ根拠ではない"]:::main
  evidence["根拠に昇格<br/>Source Bundle<br/>Context Chunk<br/>Citation"]:::main
  support["回答権限<br/>Claim Supportを確認"]:::main
  boundary["Answer Boundary<br/>回答・棄権・仮説"]:::main

  reject["捨てる<br/>戻せない候補は根拠にしない"]:::stop
  feedback["評価とfeedback<br/>次の候補作りを改善"]:::note

  raw --> signal --> evidence --> support --> boundary
  signal -. "復元不可" .-> reject
  support -. "支え不足" .-> reject
  evidence -. "品質を見る" .-> feedback
  feedback -. "改善" .-> signal
