stateDiagram-v2
  %% 現状の provider / quota guard 図: Mermaid UML stateDiagramで停止状態を見る
  direction LR

  state "候補ルート" as CandidateRoute
  state "使ってよい<br/>provider送信なし" as LocalAllowed
  state "候補として返す<br/>まだ根拠ではない" as CandidateOnly
  state "provider-backed lane<br/>semantic / OCR / Reader / rerank<br/>external search / LLM-context" as ProviderNeeded
  state "provider_gated<br/>無料枠・trial・zero-dollar quotaも停止" as Frozen
  state "traceに残す<br/>route・skip reason・guard state" as Trace
  state "後続で昇格確認<br/>Source Bundle / Context Chunk / Citation<br/>AnswerAuthorityGatekeeper" as EvidenceGate

  [*] --> CandidateRoute
  CandidateRoute --> LocalAllowed: local / fake / static / monkeypatch
  LocalAllowed --> CandidateOnly

  CandidateRoute --> ProviderNeeded: provider / network / quota が必要
  ProviderNeeded --> Frozen
  Frozen --> Trace
  Trace --> CandidateOnly

  CandidateOnly --> EvidenceGate
