flowchart TB
  %% 現状の全体アーキテクチャ図: 広い候補生成と狭い回答権限を分けて見る

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef gate fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px
  classDef side fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5

  subgraph row1["依頼から候補生成まで"]
    direction LR
    request["人 / Codex<br/>query・objective<br/>context budget"]:::main
    bridge["Narrow Codex Bridge<br/>入力を狭く受ける"]:::main
    policy["SearchLens / ObjectiveRoutePolicy<br/>関心・重み・候補ルート"]:::main
    routes["Route Portfolio [wide]<br/>local: exact / SQLite FTS / BM25 / metadata / relation<br/>projection: memory_documents / retrieval text / local topic hints<br/>provider-backed: semantic / OCR / Reader / rerank / LLM-context / managed RAG"]:::gate
    request --> bridge --> policy --> routes
  end

  subgraph row2["候補から返答まで"]
    direction LR
    candidates["Search Results / Candidates<br/>score・why_relevant・skip reason<br/>evidence_level = candidate"]:::main
    bundle["Source Bundle<br/>元投稿・media・authorへ戻す"]:::main
    chunk["Context Chunk<br/>回答用に切る"]:::main
    cite["Citation<br/>claimに結びつける"]:::main
    authority["AnswerAuthorityGatekeeper<br/>claim supportを確認"]:::main
    answer["Answer Boundary<br/>answer / needs_review / source_not_restored<br/>citation_missing / hypothesis_only / provider_gated"]:::main
    candidates --> bundle --> chunk --> cite --> authority --> answer
  end

  trace["Workflow Trace Sidecar<br/>route・guard・failure・stop reason"]:::side
  source["Source Layer<br/>tweets・bookmarks・media・raw_payloads"]:::side
  guard["ProviderApiBudgetGuard<br/>現状は承認まで停止"]:::gate

  routes --> candidates
  source -. "原本として復元に使う" .-> bundle
  routes -. "provider-backedは実行前に通す" .-> guard
  guard -. "provider_gatedも記録" .-> candidates
  answer -. "実行状態を残す" .-> trace
