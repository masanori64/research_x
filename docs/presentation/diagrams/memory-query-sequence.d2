direction: down

vars: {
  actor: "#e7f0f8"
  work: "#e7f5ed"
  data: "#fff4cf"
  stop: "#fbe4e4"
  ink: "#22313f"
}

classes: {
  box: {
    style.border-radius: 5
    style.stroke: "#4f6578"
    style.font-color: ${ink}
  }
  actor: {
    style.fill: ${actor}
  }
  work: {
    style.fill: ${work}
  }
  data: {
    style.fill: ${data}
  }
  stop: {
    style.fill: ${stop}
    style.stroke: "#b42318"
  }
}

actors: {
  grid-columns: 3
  user: "人 / AI agent\n質問を出す" {
    class: box
    class: actor
  }
  cli: "memory workflow\n1回の検索実行" {
    class: box
    class: work
  }
  trace: "実行記録\n状態と停止理由を保存" {
    class: box
    class: data
  }
}

middle: {
  grid-columns: 3
  lens: "SearchLens\n関心・重み・探索姿勢" {
    class: box
    class: work
  }
  policy: "ObjectiveRoutePolicy\n候補ルートを選ぶ" {
    class: box
    class: work
  }
  routes: "Route Portfolio\nlocal候補とprovider-backed候補" {
    class: box
    class: work
  }
}

bottom: {
  grid-columns: 3
  guard: "ProviderApiBudgetGuard\nprovider-backedだけ実行前に止める" {
    class: box
    class: stop
  }
  evidence: "Source Bundle / Context Chunk / Citation\n候補を回答入力へ昇格できるか確認" {
    class: box
    class: data
  }
  authority: "AnswerAuthorityGatekeeper\n主張を支えられるか判定" {
    class: box
    class: work
  }
}

finish: {
  grid-columns: 2
  result: "Answer Boundary\nanswer / abstain / needs_review\nsource_not_restored / citation_missing / hypothesis_only / provider_gated" {
    class: box
    class: data
  }
  trace_sidecar: "実行記録 sidecar\nroute / guard / evidence / stop reason" {
    class: box
    class: data
  }
}

halt: "途中で止まる条件\nprovider_gated・復元失敗・引用不足・主張を支えない" {
  class: box
  class: stop
}

actors -> middle: "実行開始"
middle -> bottom: "根拠確認へ"
bottom -> halt: "止まる時"
bottom -> finish: "回答境界へ"

actors.user -> actors.cli
actors.cli -> middle.lens
middle.lens -> middle.policy
middle.policy -> middle.routes
middle.routes -> bottom.guard: "provider-backed"
middle.routes -> bottom.evidence: "local candidates"
bottom.guard -> bottom.evidence: "承認済み候補"
bottom.evidence -> bottom.authority
bottom.authority -> finish.result
finish.result -> finish.trace_sidecar
finish.trace_sidecar -> actors.trace

bottom.guard -> halt: "承認・予算なし" {
  style.stroke: "#b42318"
  style.stroke-dash: 5
}
bottom.evidence -> halt: "復元・引用できない" {
  style.stroke: "#b42318"
  style.stroke-dash: 5
}
bottom.authority -> halt: "主張を支えない" {
  style.stroke: "#b42318"
  style.stroke-dash: 5
}
halt -> finish.trace_sidecar: "理由を残す" {
  style.stroke: "#b42318"
  style.stroke-dash: 5
}
