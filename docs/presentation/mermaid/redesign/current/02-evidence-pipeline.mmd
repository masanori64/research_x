flowchart LR
  %% 現状の証拠パイプライン図: 候補と根拠を混ぜない

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef stop fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px
  classDef note fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5

  raw["原本<br/>X投稿・メディア"]:::main
  hit["検索候補<br/>SQLite / FTS / 関係<br/>まだ根拠ではない"]:::main
  evidence["根拠に昇格<br/>Source Bundle<br/>Context Chunk<br/>Citation"]:::main
  claim["回答権限<br/>主張支えを確認"]:::main
  boundary["Answer Boundary<br/>answer / review / hypothesis"]:::main

  restore_stop["止める<br/>原本へ戻れない"]:::stop
  weak_stop["止める<br/>引用または主張支えが弱い"]:::stop
  control_note["図・WBS・要約<br/>根拠にしない"]:::note

  raw --> hit --> evidence --> claim --> boundary
  hit -. "復元失敗" .-> restore_stop
  evidence -. "説明資料由来" .-> control_note
  claim -. "支え不足" .-> weak_stop
