  %% 完成形の provider / quota guard 図: 承認済みProviderを候補生成として安全に使う

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef stop fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px

  route["provider-backed<br/>候補ルート"]:::main
  approval{"明示承認<br/>があるか"}:::main
  estimate["先に見積もる<br/>件数・費用"]:::main
  guard{"上限内か<br/>ProviderApiBudgetGuard"}:::main
  run["最小範囲で実行<br/>候補として扱う"]:::main
  restore["後続で昇格確認<br/>Source Bundle / Citation"]:::main
