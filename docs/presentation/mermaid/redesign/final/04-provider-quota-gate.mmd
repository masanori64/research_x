  record["記録する<br/>使用量と次の停止点"]:::main

  route --> approval
  approval -->|"いいえ"| stop --> record
  approval -->|"はい"| estimate --> guard
  guard -->|"失敗"| stop
  guard -->|"通過"| run --> restore --> record
