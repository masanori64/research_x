  request["人 / AI agent<br/>調べたい目的を渡す"]:::input

  subgraph core["research_x 完成形の主経路"]
    lens["SearchLens<br/>人間側の関心と重みを反映"]:::main
    route["ObjectiveRoutePolicy<br/>local / media / provider候補を選ぶ"]:::main
    restore["候補を根拠へ戻す<br/>Source Bundle / Context Chunk / Citation"]:::main
    authority["AnswerAuthorityGatekeeper<br/>claim support を判定"]:::main
    respond["Answer Boundary<br/>answer / abstain / review / hypothesis"]:::main
  end

  subgraph support["外部設計として見る範囲"]
    provider["外部Provider/API<br/>承認済み範囲だけ"]:::gate
    observe["監査と見える化<br/>費用・品質・停止理由"]:::side
    feedback["評価と改善<br/>失敗例を次の検索へ戻す"]:::side
  end

  request --> lens --> route --> restore --> authority --> respond
  provider -. "ProviderApiBudgetGuard後の候補だけ" .-> route
  respond -. "状態を残す" .-> observe
  observe -. "改善に使う" .-> feedback
