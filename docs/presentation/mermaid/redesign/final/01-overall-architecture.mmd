flowchart TB
  %% 完成形の全体アーキテクチャ図: AIの外部記憶として質問から答えまでを閉じる

  classDef main fill:#ffffff,stroke:#111111,color:#111111
  classDef note fill:#ffffff,stroke:#111111,color:#111111,stroke-dasharray: 5 5
  classDef gate fill:#ffffff,stroke:#111111,color:#111111,stroke-width:2px

  request["人 / AI agent<br/>目的を渡す"]:::main
  route["候補経路を選ぶ<br/>SearchLens<br/>ObjectiveRoutePolicy"]:::main
  local["ローカル候補<br/>SQLite / FTS / 関係"]:::main
  provider["外部Provider/API<br/>ProviderApiBudgetGuard後だけ"]:::gate
  evidence["根拠へ戻す<br/>Source Bundle / Citation"]:::main
  authority["回答権限<br/>主張支えを確認"]:::main
  answer["Answer Boundary<br/>答える / 止める"]:::main
  audit["監査と改善<br/>失敗理由を戻す"]:::note

  subgraph row1["質問を候補に変える"]
    direction LR
    request --> route --> local
    route -. "必要な時だけ" .-> provider
    provider -. "候補として合流" .-> local
  end

  subgraph row2["候補を回答にできるか見る"]
    direction LR
    evidence --> authority --> answer
  end

  local --> evidence
  answer -. "状態を残す" .-> audit
